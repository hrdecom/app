{
  "name": "jewelry-crm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "vite": "vite --port 5173 --strictPort",
    "dev": "wrangler pages dev --port 8788 --persist-to=.wrangler/state --compatibility-date=2025-01-15 --d1=DB=jewelry-crm-db --kv=SESSIONS --r2=IMAGES -- npm run vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "deploy": "npm run build && npm run db:migrate:remote -- --yes && wrangler pages deploy ./dist --project-name=jewelry-crm",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:exec:local": "wrangler d1 execute jewelry-crm-db --local --persist-to=.wrangler/state",
    "db:migrate:local": "wrangler d1 migrations apply jewelry-crm-db --local --persist-to=.wrangler/state",
    "db:migrate:remote": "wrangler d1 migrations apply jewelry-crm-db --remote",
    "db:reset:local": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "build:storefront": "cd storefront/personalizer && npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@remotion/core": "^1.0.0-y.46",
    "@remotion/player": "^4.0.448",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-rnd": "^10.5.3",
    "react-router-dom": "^6.26.2",
    "remotion": "^4.0.448",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^1.6.1",
    "wrangler": "^4.0.0"
  }
}
